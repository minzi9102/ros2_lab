<?xml version="1.0"?>
<robot name="ur3_simplified">
  <material name="steel_gray">
    <color rgba="0.60 0.62 0.66 1.0"/>
  </material>
  <material name="ur_blue">
    <color rgba="0.15 0.35 0.80 1.0"/>
  </material>
  <material name="joint_dark">
    <color rgba="0.18 0.18 0.18 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.25 0.08"/>
      </geometry>
      <material name="joint_dark"/>
    </visual>
  </link>

  <link name="link_1">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.20"/>
      </geometry>
      <material name="ur_blue"/>
    </visual>
  </link>

  <link name="link_2">
    <visual>
      <origin xyz="0 0 0.17" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.34"/>
      </geometry>
      <material name="steel_gray"/>
    </visual>
  </link>

  <link name="link_3">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.032" length="0.30"/>
      </geometry>
      <material name="ur_blue"/>
    </visual>
  </link>

  <link name="link_4">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.20"/>
      </geometry>
      <material name="steel_gray"/>
    </visual>
  </link>

  <link name="link_5">
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.026" length="0.16"/>
      </geometry>
      <material name="ur_blue"/>
    </visual>
  </link>

  <link name="link_6">
    <visual>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.024" length="0.12"/>
      </geometry>
      <material name="steel_gray"/>
    </visual>
  </link>

  <link name="tool0">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="joint_dark"/>
    </visual>
  </link>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="50.0" velocity="2.0"/>
  </joint>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="50.0" velocity="2.0"/>
  </joint>

  <joint name="elbow_joint" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.34" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="40.0" velocity="2.2"/>
  </joint>

  <joint name="wrist_1_joint" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 0.30" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="25.0" velocity="2.5"/>
  </joint>

  <joint name="wrist_2_joint" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="20.0" velocity="2.8"/>
  </joint>

  <joint name="wrist_3_joint" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="15.0" velocity="3.0"/>
  </joint>

  <joint name="tool0_fixed_joint" type="fixed">
    <parent link="link_6"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
  </joint>
</robot>
